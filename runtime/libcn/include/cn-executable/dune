; cerb_types.h defines the Cerberus implementation-defined types for the host,
; so it is generated by the toolchain instead of being checked in.

(rule
 (targets gen_cerb_types.exe)
 (deps gen_cerb_types.c)
 (action
  (run %{cc} -std=gnu11 %{deps} -o %{targets})))

(rule
 (targets cerb_types.h)
 (deps gen_cerb_types.exe)
 (action
  (with-stdout-to
   cerb_types.h
   (run ./gen_cerb_types.exe))))
